# Stit'Claude · Apache routing
ErrorDocument 404 /404.html

# Serve SVG files with correct MIME (just in case)
AddType image/svg+xml .svg

# No caching for HTML (so updates propagate)
<FilesMatch "\.(html)$">
  Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# Long cache for assets
<FilesMatch "\.(svg|css|woff2?|png|jpg|webp)$">
  Header set Cache-Control "public, max-age=31536000"
</FilesMatch>
